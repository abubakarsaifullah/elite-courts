NEXT_PUBLIC_SITE_URL=https://elitecourts.com.pk

# Resend SMTP contact form settings
RESEND_API_KEY=
RESEND_SMTP_PORT=465
CONTACT_RECEIVER_EMAIL=elitecourtspadel@gmail.com
CONTACT_SENDER_EMAIL="Elite Courts <noreply@elitecourts.com.pk>"

# Optional generic SMTP fallback if Resend is not used
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional Google reviews integration
# Keep these server-side only. Do not expose them with NEXT_PUBLIC_ prefixes.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Google Calendar booking/chatbot settings
# Keep these server-side only. Do not expose them with NEXT_PUBLIC_ prefixes.
GOOGLE_CALENDAR_ID=
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin portal settings
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
ADMIN_SESSION_MAX_AGE_MINUTES=120

# Public-safe booking UI settings
NEXT_PUBLIC_CHATBOT_INACTIVITY_RESET_MINUTES=15
NEXT_PUBLIC_ADMIN_PORTAL_REFRESH_SECONDS=30
